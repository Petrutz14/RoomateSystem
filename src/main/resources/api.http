    ### 1. Register a new user
POST http://localhost:8080/api/users/register
Content-Type: application/json

{
  "username": "daninepotu12345",
  "email": "daninepotu12345@yahoo.com",
  "password": "password12345"
}


### 2. Login to get a fresh token (If already registered)
POST http://localhost:8080/api/users/login
Content-Type: application/json

{
  "email": "daninepotu12345@yahoo.com",
  "password": "password12345"
}

### 3. Create an Apartment (Required for Foreign Key)
POST http://localhost:8080/api/apartments
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJkYW5pbmVwb3R1MTIzNDVAeWFob28uY29tIiwiaWF0IjoxNzY4MTY2NzkyLCJleHAiOjE3NjgyNTMxOTJ9.1yu9K8tQHPfs_sIUSUmSPdBvODVyT9sjHwAIJr4tMIM

{
  "address": "123 Main Street, Apt 4B"
}

### 4. Create an Expense (The Bill)
# Note: Check your DB for the apartmentId, usually 1 if DB was wiped
POST http://localhost:8080/api/expenses
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJkYW5pbmVwb3R1MTIzNDVAeWFob28uY29tIiwiaWF0IjoxNzY4MTY2NzkyLCJleHAiOjE3NjgyNTMxOTJ9.1yu9K8tQHPfs_sIUSUmSPdBvODVyT9sjHwAIJr4tMIM

{
  "title": "January Maintenance",
  "amount": 150.50,
  "apartmentId": 1,
  "category": "Maintenance",
  "date": "2026-01-11"
}

### 5. Make a Payment (Contribution)
# Note: expenseId is 1 for the first expense created
POST http://localhost:8080/api/payments
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJkYW5pbmVwb3R1MTIzNDVAeWFob28uY29tIiwiaWF0IjoxNzY4MTY2NzkyLCJleHAiOjE3NjgyNTMxOTJ9.1yu9K8tQHPfs_sIUSUmSPdBvODVyT9sjHwAIJr4tMIM

{
  "expenseId": 1,
  "amount": 0.50,
  "paymentDate": "2026-04-11"
}

### 6. Verify Payments for the Expense
GET http://localhost:8080/api/payments/expense/1
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJkYW5pbmVwb3R1MTIzNDVAeWFob28uY29tIiwiaWF0IjoxNzY4MTY2NzkyLCJleHAiOjE3NjgyNTMxOTJ9.1yu9K8tQHPfs_sIUSUmSPdBvODVyT9sjHwAIJr4tMIM

